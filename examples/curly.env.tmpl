# curly secrets — sourced by curly before YAML substitution.
# Copy to ~/.curly.env, fill in your tokens, chmod 600.
#
# NEVER commit this file. The .gitignore in this repo already excludes it.

# ── protocol.supply ─────────────────────────────────────────────────────────
# Get at https://protocol.supply → Settings → API Tokens
PROTOCOL_TOKEN=tok_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: act on behalf of a specific user (admin/system tokens only)
# PROTOCOL_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion ──────────────────────────────────────────────────────────────────
# Internal integration: https://www.notion.so/profile/integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ──────────────────────────────────────────────────────────────────
# Fine-grained PAT: https://github.com/settings/tokens?type=beta
# (env name must match what's in your curly.yaml — default is GH_TOKEN)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PostHog ─────────────────────────────────────────────────────────────────
# Personal API key (NOT the phc_ project key): Settings → Personal API Keys
POSTHOG_TOKEN=phx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Override for EU cloud / self-hosted
# POSTHOG_HOST=https://eu.posthog.com

# ── Apify ───────────────────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── n8n ─────────────────────────────────────────────────────────────────────
# Settings → n8n API → Create an API key
N8N_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Override for non-localhost instance
# N8N_HOST=https://n8n.example.com/api/v1

# ── Slack ───────────────────────────────────────────────────────────────────
SLACK_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Linear ──────────────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Luma (lu.ma) ────────────────────────────────────────────────────────────
# Full name=value cookie from a logged-in browser. ~30-day expiry.
#   sqlite3 ~/Library/Application\ Support/Google/Chrome/Default/Cookies \
#     "SELECT name||'='||value FROM cookies WHERE host_key LIKE '%lu.ma%' AND name='luma.auth-session-key';"
# Leave empty to use anonymous mode (public reads only).
# LUMA_AUTH_COOKIE='luma.auth-session-key=usr-xxxxxxxxxxxxxxxx'

# ── Airtable ────────────────────────────────────────────────────────────────
# Personal Access Token: https://airtable.com/create/tokens
# Scopes: data.records:read (+ :write), schema.bases:read
AIRTABLE_TOKEN=patxxxxxxxxxxxxxx.yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# ── Wilde Agency ────────────────────────────────────────────────────────────
# JWT, 7-day expiry. Refresh:
#   curl -sS -X POST https://api.wilde.agency/auth \
#     -H "Content-Type: application/json" \
#     -d '{"email":"system@wilde.agency","password":"'$SYSTEM_PASSWORD'"}' \
#     | jq -r .token
WILDE_TOKEN=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ClickUp ─────────────────────────────────────────────────────────────────
# Personal token: My Settings → Apps → API Token. Goes RAW in Authorization
# header (NOT Bearer — Bearer returns OAUTH_019).
CLICKUP_TOKEN=pk_xxxxxxxxx_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Talk to @BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mailgun ─────────────────────────────────────────────────────────────────
# Settings → API Keys (private API key, key-xxx format)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
