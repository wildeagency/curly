#!/usr/bin/env bash
# curly — a curl wrapper that reads a YAML service registry.
# https://github.com/wildeagency/curly
#
# Usage: curly <service> <path> [curl-args...]
#        curly services                          # list services from the merged config
#        curly doctor                            # check deps, config sources, and token status
#        curly init <service> [token] [k=v ...]  # write/update a service in ~/.curly.yaml
#
# `curly init` examples:
#   curly init protocol tok_xxx                    # known service: just set the token
#   curly init protocol tok_xxx ghost-user=user_x  # also set X-Ghost-User-Id header
#   curly init stripe sk_live_xxx host=https://api.stripe.com auth=bearer  # new service
#   curly init protocol                            # service exists → prompt for token
#
# Reserved k=v keys: host, auth, auth_header, user_agent, token, ghost-user.
# Anything else is added under .headers (so `Notion-Version=2026-03-11` works).
#
# Config discovery (lowest → highest precedence, deep-merged):
#   1. $HOME/.curly.yaml
#   2. /.curly.yaml, /<dir>/.curly.yaml, …, $PWD/.curly.yaml
# Closer-to-cwd files override $HOME and ancestors. Tokens in any of these
# files — keep them chmod 600. Set $CURLY_YAML to use only that file
# (skips the chain).
#
# Requires: curl, yq (v4), jq.

set -euo pipefail

# Resolve $HOME through symlinks (e.g. macOS /var → /private/var) so the
# dedup below matches what `pwd -P` produces during the ancestor walk.
HOME_REAL=$(cd "$HOME" 2>/dev/null && pwd -P || echo "$HOME")
HOME_YAML="$HOME_REAL/.curly.yaml"

# Expand ${VAR} / ${VAR:-default} in a string. Trusted config: rejects
# backticks and $() so a YAML value can't run commands.
expand() {
  # shellcheck disable=SC2016
  case "$1" in *'`'*|*'$('*) echo "curly: unsafe value: $1" >&2; exit 1 ;; esac
  local _u=0; case $- in *u*) _u=1; set +u ;; esac
  eval "printf '%s' \"$1\""
  [ "$_u" = 1 ] && set -u
}

# Discover .curly.yaml files in precedence order (lowest → highest).
# Sets CONFIG_FILES array. Returns 1 if none found.
discover_config_files() {
  CONFIG_FILES=()

  if [ -n "${CURLY_YAML:-}" ]; then
    [ -f "$CURLY_YAML" ] || return 1
    CONFIG_FILES=("$CURLY_YAML")
    return 0
  fi

  [ -f "$HOME_YAML" ] && CONFIG_FILES+=("$HOME_YAML")

  # Walk cwd → /, collecting ancestors, then read them root → cwd so closer
  # files win the deep merge. Append-only on the array side keeps bash 3.2
  # happy under `set -u` (empty `${arr[@]}` would otherwise be unbound).
  local d f i
  local ancestors=()
  d=$(pwd -P)
  while :; do
    ancestors+=("$d")
    [ "$d" = "/" ] && break
    d=$(dirname "$d")
  done

  for ((i = ${#ancestors[@]} - 1; i >= 0; i--)); do
    d="${ancestors[i]}"
    case "$d" in /) f="/.curly.yaml" ;; *) f="$d/.curly.yaml" ;; esac
    [ -f "$f" ] || continue
    [ "$f" = "$HOME_YAML" ] && continue   # already added at base
    CONFIG_FILES+=("$f")
  done

  [ "${#CONFIG_FILES[@]}" -gt 0 ]
}

# Discover + deep-merge into a single JSON blob. Sets CONFIG, CONFIG_FILES.
build_config() {
  discover_config_files || return 1
  if [ "${#CONFIG_FILES[@]}" -eq 1 ]; then
    CONFIG=$(yq -o=json '.' "${CONFIG_FILES[0]}")
  else
    CONFIG=$(yq ea -o=json '. as $i ireduce ({}; . *d $i)' "${CONFIG_FILES[@]}")
  fi
}

config_not_found() {
  if [ -n "${CURLY_YAML:-}" ]; then
    echo "curly: \$CURLY_YAML=$CURLY_YAML not found" >&2
  else
    echo "curly: no .curly.yaml found in \$HOME or ancestors of $(pwd)" >&2
    echo "  See github.com/wildeagency/curly for the starter file." >&2
  fi
}

# ─── Subcommands ────────────────────────────────────────────────────────────

case "${1:-}" in
  ""|-h|--help)
    sed -n '/^# Usage:/,/^$/p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;

  services)
    build_config || { config_not_found; exit 1; }
    jq -r '.services // {} | to_entries[] | .key + "\t" + (.value.host // "")' <<<"$CONFIG" |
      awk -F'\t' '{ printf "  %-12s %s\n", $1, $2 }'
    exit 0 ;;

  init)
    shift
    [ $# -ge 1 ] || { echo "curly init <service> [token] [k=v ...]" >&2; exit 1; }

    SERVICE=$1; shift
    case "$SERVICE" in *[!a-zA-Z0-9_-]*) echo "curly init: bad service name '$SERVICE'" >&2; exit 1 ;; esac

    # First arg is the token if it has no '=' (positional, value-only).
    INIT_TOKEN=""
    if [ $# -gt 0 ] && [ "${1#*=}" = "$1" ]; then
      INIT_TOKEN=$1; shift
    fi

    # Target file: $CURLY_YAML if set (sandbox/power-user), else $HOME/.curly.yaml.
    # Other discovered files in the chain are read-only as far as `init` cares.
    YAML="${CURLY_YAML:-$HOME_YAML}"
    if [ ! -f "$YAML" ]; then
      printf 'services: {}\n' > "$YAML"
      chmod 600 "$YAML"
      echo "→ created $YAML"
    fi

    # Detect whether the service already exists. `yq -e` exits non-zero when
    # the selected value is null/missing/false — the canonical presence check.
    if yq -e ".services.\"$SERVICE\"" "$YAML" >/dev/null 2>&1; then
      EXISTS=1
    else
      EXISTS=0
    fi

    # If new service, require host= and auth= up front.
    if [ "$EXISTS" -eq 0 ]; then
      NEW_HOST=""; NEW_AUTH=""
      for kv in "$@"; do
        case "$kv" in
          host=*) NEW_HOST=${kv#host=} ;;
          auth=*) NEW_AUTH=${kv#auth=} ;;
        esac
      done
      [ -n "$NEW_HOST" ] || { echo "curly init: new service '$SERVICE' needs host=<url>" >&2; exit 1; }
      [ -n "$NEW_AUTH" ] || { echo "curly init: new service '$SERVICE' needs auth=<bearer|basic|header|cookie|none>" >&2; exit 1; }
      SVC="$SERVICE" H="$NEW_HOST" A="$NEW_AUTH" \
        yq -i '.services[strenv(SVC)] = {"host": strenv(H), "auth": strenv(A), "token": ""}' "$YAML"
      echo "→ added service '$SERVICE' (host=$NEW_HOST auth=$NEW_AUTH)"
    fi

    # If no token was given and the existing service has an empty token, prompt.
    if [ -z "$INIT_TOKEN" ]; then
      CUR=$(yq -r ".services.\"$SERVICE\".token // \"\"" "$YAML")
      if [ -z "$CUR" ] || [ "${CUR#*xxxxx}" != "$CUR" ]; then
        if [ -t 0 ] && [ -t 1 ]; then
          printf 'Token for %s (input hidden, blank to skip): ' "$SERVICE" >&2
          stty -echo 2>/dev/null || true
          IFS= read -r INIT_TOKEN || true
          stty echo 2>/dev/null || true
          printf '\n' >&2
        fi
      fi
    fi

    # Apply token.
    if [ -n "$INIT_TOKEN" ]; then
      SVC="$SERVICE" V="$INIT_TOKEN" yq -i '.services[strenv(SVC)].token = strenv(V)' "$YAML"
    fi

    # Apply remaining key=value extras.
    for kv in "$@"; do
      case "$kv" in *=*) ;; *) continue ;; esac
      k=${kv%%=*}; v=${kv#*=}
      case "$k" in
        host|auth|auth_header|user_agent|token)
          SVC="$SERVICE" K="$k" V="$v" yq -i '.services[strenv(SVC)][strenv(K)] = strenv(V)' "$YAML" ;;
        ghost-user|ghost_user)
          SVC="$SERVICE" V="$v" yq -i '.services[strenv(SVC)].headers["X-Ghost-User-Id"] = strenv(V)' "$YAML" ;;
        *)
          SVC="$SERVICE" K="$k" V="$v" yq -i '.services[strenv(SVC)].headers[strenv(K)] = strenv(V)' "$YAML" ;;
      esac
    done

    chmod 600 "$YAML"
    echo "✓ $SERVICE saved to $YAML"
    exit 0 ;;

  doctor)
    for d in curl yq jq; do
      command -v "$d" >/dev/null || { echo "✗ $d missing (brew install $d)"; exit 1; }
    done
    echo "✓ deps: curl yq jq"

    if ! discover_config_files; then
      config_not_found
      exit 1
    fi
    echo "✓ config sources (later overrides earlier):"
    for f in "${CONFIG_FILES[@]}"; do
      perms=$(stat -f '%Lp' "$f" 2>/dev/null || stat -c '%a' "$f" 2>/dev/null)
      printf "    %s  (perms: %s)\n" "$f" "$perms"
      case "$perms" in 600|400) ;; *) echo "      ⚠ tokens are world-readable. Run: chmod 600 $f" ;; esac
      yq '.' "$f" >/dev/null || { echo "✗ yaml parse error in $f"; exit 1; }
    done
    build_config
    echo
    while IFS=$'\t' read -r svc auth token; do
      tok=$(expand "$token")
      case "$auth" in
        none)  state="ok" ;;
        basic) case "$tok" in ""|:*|*:) state="MISSING TOKEN — set services.$svc.token in your curly config" ;; *) state="ok" ;; esac ;;
        *)     [ -z "$tok" ] && state="MISSING TOKEN — set services.$svc.token in your curly config" || state="ok" ;;
      esac
      printf "  %-12s %-7s %s\n" "$svc" "$auth" "$state"
    done < <(jq -r '.services // {} | to_entries[] |
      .key + "\t" + (.value.auth // "none") + "\t" + (.value.token // "")' <<<"$CONFIG")
    exit 0 ;;
esac

# ─── Request path: curly <service> <path> [curl-args...] ────────────────────

[ $# -ge 2 ] || { sed -n '/^# Usage:/,/^$/p' "$0" | sed 's/^# \{0,1\}//' >&2; exit 1; }

SERVICE=$1
REQ_PATH=$2
shift 2

build_config || { config_not_found; echo "  Run: curly doctor" >&2; exit 1; }

# Pull the merged service entry as JSON.
ENTRY=$(jq -c ".services[\"$SERVICE\"] // null" <<<"$CONFIG")
[ "$ENTRY" = "null" ] && {
  echo "curly: unknown service '$SERVICE'" >&2
  echo "  Available: $(jq -r '.services // {} | keys | join(" ")' <<<"$CONFIG")" >&2
  echo "  Sources: ${CONFIG_FILES[*]}" >&2
  exit 1
}

HOST=$(expand "$(jq -r '.host        // ""'    <<<"$ENTRY")")
TOKEN=$(expand "$(jq -r '.token       // ""'   <<<"$ENTRY")")
AUTH=$(jq -r        '.auth        // "none"'    <<<"$ENTRY")
AUTH_HEADER=$(jq -r '.auth_header // ""'        <<<"$ENTRY")
USER_AGENT=$(expand "$(jq -r '.user_agent // ""' <<<"$ENTRY")")

# Leading "/" is optional — always prepend if missing. This includes @refs
# like "@protocol/foo" (which become "/@protocol/foo"), otherwise curl
# concatenates host+path with no separator and parses "host@path" as URL
# userinfo, producing "Could not resolve host" errors.
case "$REQ_PATH" in /*) ;; *) REQ_PATH=/$REQ_PATH ;; esac

# ─── Build curl args ────────────────────────────────────────────────────────

CURL=(-s)
[ -n "$USER_AGENT" ] && CURL+=(-A "$USER_AGENT")

no_token() { echo "curly: no token for '$SERVICE' — set services.$SERVICE.token in your curly config (sources: ${CONFIG_FILES[*]})" >&2; exit 1; }

case "$AUTH" in
  none)   ;;
  bearer) [ -n "$TOKEN" ] || no_token
          CURL+=(-H "Authorization: Bearer $TOKEN") ;;
  basic)  case "$TOKEN" in ""|:*|*:) echo "curly: '$SERVICE' needs user:pass in token" >&2; exit 1 ;; esac
          CURL+=(-u "$TOKEN") ;;
  header) [ -n "$TOKEN"       ] || no_token
          [ -n "$AUTH_HEADER" ] || { echo "curly: '$SERVICE' auth=header needs auth_header" >&2; exit 1; }
          CURL+=(-H "$AUTH_HEADER: $TOKEN") ;;
  cookie) [ -n "$TOKEN" ] || no_token
          CURL+=(-H "Cookie: $TOKEN") ;;
  *)      echo "curly: '$SERVICE' has unknown auth '$AUTH'" >&2; exit 1 ;;
esac

# Static headers from the merged .headers map. Empty values get dropped.
while IFS=$'\t' read -r name value; do
  [ -z "$name" ] && continue
  value=$(expand "$value")
  [ -n "$value" ] && CURL+=(-H "$name: $value")
done < <(jq -r '.headers // {} | to_entries[] | .key + "\t" + .value' <<<"$ENTRY")

# Auto Content-Type when the caller sends a JSON body.
for a in "$@"; do
  case "$a" in -d|--data|--data-raw|--data-binary|--json)
    CURL+=(-H "Content-Type: application/json"); break ;;
  esac
done

exec curl "${CURL[@]}" "${HOST}${REQ_PATH}" "$@"
